SOLUTION to QUESTION 4:
_____________________________________________________________________

SELECT p.name as mastermind, count(fb.event_name)as SQLSymphonyConcert_Attd
FROM facebook_event_checkin fb
	JOIN person p
		ON fb.person_id = p.id
	JOIN drivers_license dl
		ON p.license_id = dl.id
WHERE  dl.gender = 'female'
	AND (dl.height BETWEEN 65 AND 67)
	AND LOWER(dl.hair_color) = 'red'
	AND UPPER(fb.event_name) LIKE '%SQL%'
	AND UPPER(dl.car_make) like '%TESLA%'
	AND fb.date LIKE '201712__'

